#!/usr/bin/env bash
# pre-commit hook — auto-bumps firmware patch version + UTC build date,
# then re-stages the touched files so the bump is part of THIS commit.
#
# Skips the bump if firmware/index.html aren't part of the staged change
# AND no changes are staged at all (avoids bumping for empty/dummy commits).
#
# To skip the bump for a specific commit (e.g. doc-only):
#   SKIP_FW_BUMP=1 git commit -m "docs: ..."

set -e

# Allow opt-out
if [ "$SKIP_FW_BUMP" = "1" ]; then
  exit 0
fi

# Only run if there are staged changes at all
if git diff --cached --quiet; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ ! -f tools/bump-firmware.py ]; then
  echo "[pre-commit] tools/bump-firmware.py not found, skipping" >&2
  exit 0
fi

echo "[pre-commit] auto-bumping firmware..." >&2
python tools/bump-firmware.py >&2 || {
  echo "[pre-commit] bump failed, aborting commit" >&2
  exit 1
}

# Re-stage the files the bump touched so they go into this commit
git add firmware/v1-maqueen-lib.ts index.html
exit 0
